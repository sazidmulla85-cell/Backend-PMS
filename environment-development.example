# Visible reference copy of ../.env.development.example.
# Create the real environment file at the PMS-System root:
#   cp ../.env.development.example ../.env.development

APP_PROFILE=dev
SERVER_PORT=8080

PMS_DB_HOST=127.0.0.1
PMS_DB_PORT=3306
PMS_DB_NAME=hotel_pms_dev
PMS_DB_TIMEZONE=Asia/Kolkata
PMS_DB_USERNAME=pms_user
PMS_DB_PASSWORD=PmsUser@123
PMS_DB_POOL_SIZE=10
PMS_DB_MIN_IDLE=2
PMS_DB_CONNECTION_TIMEOUT_MS=30000

PMS_UPLOAD_DIR=./uploads
PMS_CORS_ALLOWED_ORIGINS=http://localhost:4200
PMS_FRONTEND_BASE_URL=http://localhost:4200
PMS_MULTIPART_MAX_FILE_SIZE=10MB
PMS_MULTIPART_MAX_REQUEST_SIZE=25MB

PMS_JWT_SECRET=dev-only-jwt-secret-change-me-1234567890
PMS_JWT_EXPIRATION_MS=86400000
PMS_PASSWORD_RESET_EXPIRATION_MINUTES=30
PMS_SEED_ENABLED=true
PMS_SUPER_ADMIN_NAME="Platform Super Admin"
PMS_SUPER_ADMIN_EMAIL=superadmin@pms.local
PMS_SUPER_ADMIN_PHONE=9999999999
PMS_SUPER_ADMIN_PASSWORD=superadmin123

PMS_EMAIL_ENABLED=false
PMS_EMAIL_SEND_CHECK_IN=true
PMS_EMAIL_SEND_CHECK_OUT=true
PMS_GMAIL_FROM=no-reply@hotelpms.local
PMS_GMAIL_USERNAME=
PMS_GMAIL_APP_PASSWORD=
