# Visible reference copy of ../.env.production.example.
# Create and edit the real production file at the PMS-System root:
#   cp ../.env.production.example ../.env.production

FRONTEND_PORT=80
PMS_FRONTEND_BASE_URL=https://pms.example.com
PMS_CORS_ALLOWED_ORIGINS=https://pms.example.com

APP_PROFILE=prod
SERVER_PORT=8080
PMS_UPLOAD_DIR=/var/lib/hotel-pms/uploads

MYSQL_DATABASE=hotel_pms
MYSQL_USER=pms_app
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password
PMS_DB_POOL_SIZE=10
PMS_DB_MIN_IDLE=2
PMS_DB_CONNECTION_TIMEOUT_MS=30000

PMS_JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
PMS_JWT_EXPIRATION_MS=86400000
PMS_PASSWORD_RESET_EXPIRATION_MINUTES=30
JAVA_OPTS=-Xms256m -Xmx768m

PMS_MULTIPART_MAX_FILE_SIZE=10MB
PMS_MULTIPART_MAX_REQUEST_SIZE=25MB

PMS_EMAIL_ENABLED=false
PMS_EMAIL_SEND_CHECK_IN=true
PMS_EMAIL_SEND_CHECK_OUT=true
PMS_GMAIL_FROM=
PMS_GMAIL_USERNAME=
PMS_GMAIL_APP_PASSWORD=

PMS_BACKEND_UPSTREAM=backend:8080
PMS_FRONTEND_API_BASE_URL=/api
PMS_NGINX_CLIENT_MAX_BODY_SIZE=25m
